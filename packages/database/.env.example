# Wine Cellar Database - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection string
# Development: Uses port 5433 to avoid conflicts with other PostgreSQL instances
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/wine_cellar"

# For tests, use a separate database:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5433/wine_cellar_test"
