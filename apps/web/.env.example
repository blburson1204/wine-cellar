# Wine Cellar Web - Environment Variables
# Copy this file to .env.local and fill in your values

# =============================================================================
# API CONFIGURATION
# =============================================================================
# Backend API URL for server-side requests and rewrites
# Development default: http://localhost:3001
# Production: Set to your Railway/deployed API URL
# NEXT_PUBLIC_API_URL=http://localhost:3001

# Node environment: development, production, test
# NODE_ENV=development

# =============================================================================
# BASIC AUTH (Optional - for production deployment)
# =============================================================================
# When both are set, HTTP Basic Auth is required for all pages
# Leave unset for local development without auth
# AUTH_USERNAME=admin
# AUTH_PASSWORD=your-secure-password
