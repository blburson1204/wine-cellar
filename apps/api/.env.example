# Wine Cellar API - Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection string
# Development: Uses port 5433 to avoid conflicts with other PostgreSQL instances
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/wine_cellar"

# =============================================================================
# SERVER
# =============================================================================
# Server port (default: 3001)
# PORT=3001

# Node environment: development, production, test
# NODE_ENV=development

# Logging level: error, warn, info, debug (default: info)
# LOG_LEVEL=info

# =============================================================================
# CORS
# =============================================================================
# Allowed origin for CORS requests
# In development, leave unset for permissive CORS
# In production, set to your frontend URL
# CORS_ORIGIN=https://your-frontend-domain.com

# =============================================================================
# STORAGE
# =============================================================================
# Storage provider: local or cloudinary (default: local)
# STORAGE_PROVIDER=local

# Directory for local file uploads (default: ./uploads/wines)
# UPLOAD_DIR=./uploads/wines

# Cloudinary configuration (required when STORAGE_PROVIDER=cloudinary)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# Legacy S3 configuration (not currently used)
# AWS_S3_BUCKET=
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# =============================================================================
# BASIC AUTH (Optional - for production deployment)
# =============================================================================
# When both are set, HTTP Basic Auth is required for all requests except /api/health
# Leave unset for local development without auth
# AUTH_USERNAME=admin
# AUTH_PASSWORD=your-secure-password
