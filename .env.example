# Wine Cellar - Root Environment Variables
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE
# =============================================================================
# PostgreSQL connection string
# Development: Uses port 5433 to avoid conflicts with other PostgreSQL instances
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/wine_cellar"

# =============================================================================
# BASIC AUTH (Optional - for production deployment)
# =============================================================================
# When both are set, HTTP Basic Auth is required for all requests
# Leave unset for local development without auth
# AUTH_USERNAME=admin
# AUTH_PASSWORD=your-secure-password
